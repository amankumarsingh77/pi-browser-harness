      "description": "Capture screenshots of 4 already-loaded tabs",
      "sequentialTurns": 8,
      "sequentialLatencyMs": 3040,
      "parallelLatencyMs": 760,
      "expectedSpeedup": 4.0,
      "currentBehavior": "switch_tab + screenshot per tab, sequential.",
      "blockingFactor": "switch_tab_is_not_parallel_safe"
