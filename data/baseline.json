{
  "_schema": "pi-browser-harness-baseline-v1",
  "meta": {
    "createdAt": "2026-05-04T21:14:43Z",
    "commit": "7d70b2b",
    "branch": "main",
    "architecture": "single-mutable-sessionId-no-mutex",
    "description": "Pre-parallel-execution baseline. All tools share one global sessionId/targetId and pageCache. CDP requests are pipelined over a single WebSocket but tool handlers execute concurrently when pi emits parallel tool_calls.",
    "chromeSetup": "Local Chrome with --remote-debugging-port=9222, typical broadband (~50ms RTT to most sites)"
  },
  "toolBaselines": {
    "browser_click": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 25,
      "p99LatencyMs": 80,
      "bottleneck": "CDP round-trip × 2 (mousePressed + mouseReleased)",
      "notes": "Mutates page focus. Must not race with scroll/type/navigate on same tab."
    },
    "browser_type": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 30,
      "p99LatencyMs": 100,
      "bottleneck": "Input.insertText or char-by-char dispatch",
      "notes": "Mutates focused input. Order-sensitive with click (must click first)."
    },
    "browser_press_key": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 20,
      "p99LatencyMs": 60,
      "bottleneck": "Input.dispatchKeyEvent round-trip",
      "notes": "Mutates page state (Enter submits forms, Escape closes modals)."
    },
    "browser_dispatch_key": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 20,
      "p99LatencyMs": 60,
      "bottleneck": "Runtime.callFunctionOn for DOM KeyboardEvent",
      "notes": "React/Vue synthetic event dispatch. State-dependent."
    },
    "browser_scroll": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 15,
      "p99LatencyMs": 50,
      "bottleneck": "Input.dispatchMouseEvent (wheel)",
      "notes": "Mutates scrollY. Race with click changes target coordinates."
    },
    "browser_navigate": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 800,
      "p99LatencyMs": 3500,
      "bottleneck": "Network + DOM load. Does NOT include wait_for_load.",
      "notes": "Navigation invalidates pageCache and session state."
    },
    "browser_new_tab": {
      "category": "tab-creation",
      "safeToParallelize": true,
      "avgLatencyMs": 120,
      "p99LatencyMs": 300,
      "bottleneck": "Target.createTarget + Target.attachToTarget + enableDomains",
      "notes": "Operates on browser target (sessionId: null). Independent of page session."
    },
    "browser_open_urls": {
      "category": "tab-creation",
      "safeToParallelize": true,
      "avgLatencyMs": 150,
      "p99LatencyMs": 400,
      "perUrlOverheadMs": 80,
      "bottleneck": "Target.createTarget per URL",
      "notes": "Currently opens tabs sequentially internally. Huge parallelization opportunity."
    },
    "browser_switch_tab": {
      "category": "context-switch",
      "safeToParallelize": false,
      "avgLatencyMs": 80,
      "p99LatencyMs": 200,
      "bottleneck": "Target.activateTarget + attachToTarget + enableDomains",
      "notes": "CRITICAL: mutates global sessionId/targetId. Absolutely cannot run concurrently with any page tool."
    },
    "browser_list_tabs": {
      "category": "observation",
      "safeToParallelize": true,
      "avgLatencyMs": 15,
      "p99LatencyMs": 40,
      "bottleneck": "Target.getTargets",
      "notes": "Read-only browser-target call."
    },
    "browser_current_tab": {
      "category": "observation",
      "safeToParallelize": true,
      "avgLatencyMs": 5,
      "p99LatencyMs": 15,
      "bottleneck": "In-memory lookup only",
      "notes": "No CDP call. Reads cached session.current()."
    },
    "browser_screenshot": {
      "category": "observation",
      "safeToParallelize": true,
      "avgLatencyMs": 350,
      "p99LatencyMs": 1200,
      "bottleneck": "Page.captureScreenshot + base64 decode + disk write",
      "notes": "Read-only but heavy. CDP pipelining serializes on Chrome side, but no state mutation."
    },
    "browser_page_info": {
      "category": "observation",
      "safeToParallelize": true,
      "avgLatencyMs": 20,
      "p99LatencyMs": 60,
      "bottleneck": "Runtime.evaluate (cached for 1s)",
      "notes": "Uses pageCache with 1s TTL. Race: two parallel calls may both miss cache and evaluate."
    },
    "browser_execute_js": {
      "category": "observation",
      "safeToParallelize": true,
      "avgLatencyMs": 25,
      "p99LatencyMs": 80,
      "bottleneck": "Runtime.evaluate returnByValue",
      "notes": "Read-only if expression is pure. Agent may mutate DOM; we trust the agent."
    },
    "browser_run_script": {
      "category": "batch",
      "safeToParallelize": true,
      "avgLatencyMs": 500,
      "p99LatencyMs": 5000,
      "bottleneck": "Script complexity + Node.js compilation",
      "notes": "Runs in harness process, not Chrome. CPU-bound. Can be parallel with browser tools."
    },
    "browser_wait": {
      "category": "delay",
      "safeToParallelize": true,
      "avgLatencyMs": 1000,
      "p99LatencyMs": 5000,
      "bottleneck": "setTimeout in tool handler",
      "notes": "Wastes wall-clock time. Parallelizing doesn't help much unless other work happens concurrently."
    },
    "browser_wait_for_load": {
      "category": "delay",
      "safeToParallelize": false,
      "avgLatencyMs": 1500,
      "p99LatencyMs": 8000,
      "bottleneck": "document.readyState polling",
      "notes": "Coupled to specific tab navigation. Not meaningful to parallelize."
    },
    "browser_go_back": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 600,
      "p99LatencyMs": 2500,
      "bottleneck": "History navigation + partial page reload",
      "notes": "Navigation mutation. Invalidates pageCache."
    },
    "browser_go_forward": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 600,
      "p99LatencyMs": 2500,
      "bottleneck": "History navigation + partial page reload",
      "notes": "Navigation mutation. Invalidates pageCache."
    },
    "browser_reload": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 900,
      "p99LatencyMs": 3500,
      "bottleneck": "Full page reload",
      "notes": "Navigation mutation. Invalidates pageCache."
    },
    "browser_handle_dialog": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 30,
      "p99LatencyMs": 80,
      "bottleneck": "Page.handleJavaScriptDialog",
      "notes": "Mutates dialog state. Must not race with pageInfo that reads dialog."
    },
    "browser_http_get": {
      "category": "external",
      "safeToParallelize": true,
      "avgLatencyMs": 300,
      "p99LatencyMs": 2000,
      "bottleneck": "Network fetch outside Chrome",
      "notes": "Independent of browser state. Prime candidate for parallelization."
    },
    "browser_get_network_log": {
      "category": "observation",
      "safeToParallelize": true,
      "avgLatencyMs": 50,
      "p99LatencyMs": 150,
      "bottleneck": "PerformanceObserver or buffered entries",
      "notes": "Read-only. DEPRECATED in v0.3."
    },
    "browser_upload_file": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 100,
      "p99LatencyMs": 300,
      "bottleneck": "DOM.setFileInputFiles",
      "notes": "Mutates form state."
    },
    "browser_download": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 50,
      "p99LatencyMs": 150,
      "bottleneck": "Browser.setDownloadBehavior",
      "notes": "Global browser setting. Race if two tools set different download paths."
    },
    "browser_print_to_pdf": {
      "category": "observation",
      "safeToParallelize": true,
      "avgLatencyMs": 800,
      "p99LatencyMs": 3000,
      "bottleneck": "Page.printToPDF + file write",
      "notes": "Read-only rendering. Heavy like screenshot."
    },
    "browser_viewport_resize": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 40,
      "p99LatencyMs": 120,
      "bottleneck": "Emulation.setDeviceMetricsOverride + resize event cascade",
      "notes": "Mutates viewport. Affects coordinates for subsequent click/scroll."
    },
    "browser_drag_and_drop": {
      "category": "mutation",
      "safeToParallelize": false,
      "avgLatencyMs": 60,
      "p99LatencyMs": 200,
      "bottleneck": "Input.dispatchDragEvent sequence",
      "notes": "Multi-step mouse event sequence. Order-sensitive."
    }
  },
  "scenarios": {
