      "currentBehavior": "browser_open_urls creates tabs sequentially internally. No parallel tab creation.",
      "blockingFactor": "sequential_target_creation"
    },
    "researchExtract4Tabs": {
      "description": "Switch to 4 tabs and extract text from each",
