  },
  "currentRisks": {
    "sessionIdRace": {
      "severity": "high",
      "description": "browser_switch_tab mutates global sessionId. If pi executes switch_tab concurrently with click/type/scroll/navigate on another tab, the second tool operates on the wrong tab.",
      "reproduction": "Emit browser_switch_tab(A) + browser_click(B) in same assistant turn. Both may execute on A or both on B depending on interleaving."
    },
    "pageCacheRace": {
      "severity": "medium",
      "description": "pageCache is unprotected shared mutable state. Two parallel browser_page_info calls can both miss cache, both evaluate JS, and the second write overwrites the first with slightly stale data.",
      "impact": "Incorrect page dimensions or stale coordinates for subsequent click."
    },
    "navigationInvalidationRace": {
      "severity": "medium",
      "description": "browser_navigate sets pageCache = null. A concurrent browser_screenshot may capture the old page or the new page unpredictably.",
      "impact": "Screenshot shows wrong page state."
    }
  },
